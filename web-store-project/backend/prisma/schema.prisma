// prisma/schema.prisma

// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PartType {
  CASE
  COOLER
  CPU
  GPU
  MOBO
  OS
  PSU
  RAM
  STORAGE
}

model User {
  id         String      @id
  cart       Cart?
  favourites Favourite[]
  orders     Order[]
}


model Part {
  id       String   @id
  name     String
  price    Float
  partType PartType
  stock    Int

  case    Case?
  cooler  Cooler?
  cpu     CPU?
  gpu     GPU?
  mobo    MOBO?
  os      OS?
  psu     PSU?
  ram     RAM?
  storage Storage?

  cartItems  CartItem[]
  orderItems OrderItem[]
  favourites Favourite[]
}

model CartItem {
  id       String @id @default(uuid())
  quantity Int

  partId String
  part   Part   @relation(fields: [partId], references: [id])

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id])
}

model Cart {
  id     String     @id @default(uuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id])
  items  CartItem[]
}

model Favourite {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  partId String
  part   Part   @relation(fields: [partId], references: [id])
}

model Order {
  id     Int         @id @default(autoincrement())
  userId String
  user   User        @relation(fields: [userId], references: [id])
  total  Float
  date   DateTime    @default(now())
  items  OrderItem[]
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int

  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  partId String
  part   Part   @relation(fields: [partId], references: [id])
}

model Case {
  partId String @id
  part   Part   @relation(fields: [partId], references: [id])

  type             String
  color            String
  psu              String?
  side_panel       String
  external_volume  Float
  internal_35_bays Int
}

model Storage {
  partId String @id
  part   Part   @relation(fields: [partId], references: [id])

  capacity     Float
  price_per_gb Float?
  type         String
  cache        Float?
  form_factor  String
  interface    String
}

model Cooler {
  partId String @id
  part   Part   @relation(fields: [partId], references: [id])

  rpm         String
  noise_level String?
  color       String
  size        Float?
}

model CPU {
  partId String @id
  part   Part   @relation(fields: [partId], references: [id])

  core_count        Int
  core_clock        Float
  boost_clock       Float
  microarchitecture String?
  tdp               Int
  graphics          String?
}

model GPU {
  partId String @id
  part   Part   @relation(fields: [partId], references: [id])

  chipset     String
  memory      Int
  core_clock  Float
  boost_clock Float?
  color       String
  length      Float
}

model MOBO {
  partId String @id
  part   Part   @relation(fields: [partId], references: [id])

  socket       String
  form_factor  String
  max_memory   Int
  memory_slots Int
  color        String
}

model OS {
  partId String @id
  part   Part   @relation(fields: [partId], references: [id])

  mode       String
  max_memory Int
}

model PSU {
  partId String @id
  part   Part   @relation(fields: [partId], references: [id])

  type       String
  efficiency String
  wattage    Int
  modular    String
  color      String?
}

model RAM {
  partId String @id
  part   Part   @relation(fields: [partId], references: [id])

  speed              String
  modules            String
  color              String
  first_word_latency Float
  cas_latency        Float
}